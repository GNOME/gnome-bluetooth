#: lib/bluetooth-pairing-dialog.c:87 lib/bluetooth-pairing-dialog.c:94
#: lib/bluetooth-pairing-dialog.c:108
msgid "Confirm Bluetooth PIN"
msgstr "ຢືນຢັນ PIN ບລູທູດ"

#: lib/bluetooth-pairing-dialog.c:88
#, c-format
msgid "Please confirm the PIN that was entered on “%s”."
msgstr "ກະລຸນາຢືນຢັນລະຫັດ PIN ທີ່ໄດ້ປ້ອນໃນ “%s”."

#: lib/bluetooth-pairing-dialog.c:92 lib/bluetooth-pairing-dialog.c:105
#: lib/bluetooth-pairing-dialog.c:153
msgid "C_onfirm"
msgstr "_ຢືນຢັນ"

#: lib/bluetooth-pairing-dialog.c:95
#, c-format
msgid ""
"Confirm the Bluetooth PIN for “%s”. This can usually be found in the "
"device’s manual."
msgstr "ຢືນຢັນ PIN ບລູທູດສຳລັບ “%s”. ໂດຍປົກກະຕິແລ້ວສາມາດຊອກຫາໄດ້ໃນຄູ່ມືຂອງອຸປະກອນ."

#: lib/bluetooth-pairing-dialog.c:101
#, c-format
msgid "Pairing “%s”"
msgstr "ກຳລັງຈັບຄູ່ “%s”"

#: lib/bluetooth-pairing-dialog.c:109
#, c-format
msgid ""
"Please confirm that the following PIN matches the one displayed on “%s”."
msgstr "ກະລຸນາຢືນຢັນວ່າລະຫັດ PIN ຕໍ່ໄປນີ້ຕົງກັນກັບລະຫັດທີ່ສະແດງຢູ່ເທິງ “%s”."

#: lib/bluetooth-pairing-dialog.c:114
msgid "Bluetooth Pairing Request"
msgstr "ຄຳຂໍຈັບຄູ່ບລູທູດ"

#: lib/bluetooth-pairing-dialog.c:115
#, c-format
msgid "“%s” wants to pair with this device. Do you want to allow pairing?"
msgstr "“%s” ຕ້ອງການຈັບຄູ່ກັບອຸປະກອນນີ້. ທ່ານຕ້ອງການອະນຸຍາດການຈັບຄູ່ບໍ່?"

#: lib/bluetooth-pairing-dialog.c:120
msgid "Confirm Bluetooth Connection"
msgstr "ຢືນຢັນການເຊື່ອມຕໍ່ບລູທູດ"

#: lib/bluetooth-pairing-dialog.c:121
#, c-format
msgid "“%s” wants to connect with this device. Do you want to allow it?"
msgstr "“%s” ຕ້ອງການເຊື່ອມຕໍ່ກັບອຸປະກອນນີ້. ທ່ານຕ້ອງການອະນຸຍາດບໍ່?"

#: lib/bluetooth-pairing-dialog.c:129
#, c-format
msgid "Please enter the following PIN on “%s”."
msgstr "ກະລຸນາປ້ອນລະຫັດ PIN ຕໍ່ໄປນີ້ໃສ່ “%s”."

#: lib/bluetooth-pairing-dialog.c:132
#, c-format
msgid ""
"Please enter the following PIN on “%s”. Then press “Return” on the keyboard."
msgstr "ກະລຸນາປ້ອນລະຫັດ PIN ຕໍ່ໄປນີ້ໃສ່ “%s”. ຈາກນັ້ນກົດປຸ່ມ “Return” ເທິງແປ້ນພິມ."

#: lib/bluetooth-pairing-dialog.c:137
msgid ""
"Please move the joystick of your iCade in the following directions. Then "
"press any of the white buttons."
msgstr "ກະລຸນາເລື່ອນຈອຍສະຕິກຂອງ iCade ຂອງທ່ານໄປຕາມທິດທາງຕໍ່ໄປນີ້. ຈາກນັ້ນກົດປຸ່ມສີຂາວປຸ່ມໃດກໍໄດ້."

#: lib/bluetooth-pairing-dialog.c:145
msgid "_Allow"
msgstr "_ອະນຸຍາດ"

#: lib/bluetooth-pairing-dialog.c:148
msgid "_Dismiss"
msgstr "_ບໍ່ສົນໃຈ"

#: lib/bluetooth-pairing-dialog.c:156 lib/bluetooth-pairing-dialog.ui:15
#: lib/bluetooth-settings-widget.c:1311 sendto/main.c:447 sendto/main.c:699
msgid "_Cancel"
msgstr "_ຍົກເລີກ"

#: lib/bluetooth-pairing-dialog.ui:23
msgid "_Accept"
msgstr "_ຍອມຮັບ"

#: lib/bluetooth-settings-row.c:78 lib/bluetooth-settings-row.ui:12
msgid "Not Set Up"
msgstr "ຍັງບໍ່ໄດ້ຕັ້ງຄ່າ"

#: lib/bluetooth-settings-row.c:80
msgid "Connected"
msgstr "ເຊື່ອມຕໍ່ແລ້ວ"

#: lib/bluetooth-settings-row.c:82
msgid "Disconnected"
msgstr "ຕັດການເຊື່ອມຕໍ່ແລ້ວ"

#: lib/bluetooth-settings-widget.c:1141 lib/settings.ui:71
msgid "Yes"
msgstr "ແມ່ນ"

#: lib/bluetooth-settings-widget.c:1141
msgid "No"
msgstr "ບໍ່"

#. translators: first %s is the name of the computer, for example:
#. * Visible as “Bastien Nocera’s Computer” followed by the
#. * location of the Downloads folder.
#: lib/bluetooth-settings-widget.c:1233
#, c-format
msgid ""
"Visible as “%s” and available for Bluetooth file transfers. Transferred "
"files are placed in the <a href=\"%s\">Downloads</a> folder."
msgstr "ເບິ່ງເຫັນເປັນ “%s” ແລະສາມາດຮັບ-ສົ່ງໄຟລ໌ຜ່ານບລູທູດໄດ້. ໄຟລ໌ທີ່ໂອນຍ້າຍຈະຖືກເກັບໄວ້ໃນໂຟລເດີ <a href=\"%s\">ດາວໂຫຼດ</a>."

#: lib/bluetooth-settings-widget.c:1303
msgid "Forget Device?"
msgstr "ລືມອຸປະກອນນີ້ບໍ່?"

#: lib/bluetooth-settings-widget.c:1306
#, c-format
msgid ""
"“%s” will be removed from your saved devices. You will have to set it up "
"again to use it."
msgstr "“%s” ຈະຖືກລຶບອອກຈາກອຸປະກອນທີ່ບັນທຶກໄວ້ຂອງທ່ານ. ທ່ານຈະຕ້ອງໄດ້ຕັ້ງຄ່າມັນໃໝ່ເພື່ອໃຊ້ງານ."

#: lib/bluetooth-settings-widget.c:1312
msgid "_Forget"
msgstr "_ລືມ"

#. Translators: %s is the name of the filename received
#: lib/bluetooth-settings-obexpush.c:145
#, c-format
msgid "You received “%s” via Bluetooth"
msgstr "ທ່ານໄດ້ຮັບ “%s” ຜ່ານບລູທູດ"

